{
  "name": "p5.capture",
  "version": "1.6.0",
  "description": "super easy recording for p5.js animations 📸",
  "keywords": [
    "sketch",
    "p5js",
    "p5",
    "p5.js",
    "processing",
    "art",
    "creative",
    "creative-coding"
  ],
  "homepage": "https://github.com/tapioca24/p5.capture",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tapioca24/p5.capture.git"
  },
  "license": "MIT",
  "author": "tapioca24",
  "browser": "dist/p5.capture.umd.js",
  "types": "./index.d.ts",
  "files": [
    "dist",
    "index.d.ts"
  ],
  "scripts": {
    "build": "tsc && vite build",
    "format": "prettier --write .",
    "setup": "playwright install",
    "prepublishOnly": "pnpm build && pnpm test:unit run && pnpm test:e2e:skipbuild",
    "test:e2e": "playwright test",
    "test:e2e:skipbuild": "SKIP_BUILD=true pnpm test:e2e",
    "test:unit": "vitest",
    "update:readme": "node scripts/update-readme.js"
  },
  "dependencies": {
    "events": "3.3.0",
    "fflate": "0.8.2",
    "gif.js": "0.2.0",
    "h264-mp4-encoder": "1.0.12",
    "webm-writer": "1.0.0"
  },
  "devDependencies": {
    "@playwright/test": "1.58.2",
    "@types/events": "3.0.3",
    "@types/gif.js": "0.2.5",
    "@types/p5": "1.7.7",
    "happy-dom": "17.6.3",
    "prettier": "3.8.1",
    "strict-event-emitter-types": "2.0.0",
    "typescript": "4.9.5",
    "vite": "4.5.14",
    "vitest": "3.2.4"
  }
}
